



outPredWide<- readRDS("3_Output/full_analysis_results_26_06_05_wide.rds")
outPredFine<- readRDS("3_Output/full_analysis_results_26_06_05_fine_fine.rds")


extractTables<- function(outPred, whichCost=NULL){
  cat("Performance")
  perfTab<- outPred$perfAll
  perfSeq<- perfTab[perfTab$type=="dedaptive", ]
  perfFix<- perfTab[perfTab$type=="all", ]
  
  plot(perfSeq$cM, perfSeq$totCost, ylim=c(0, 0.8), type="b")
  points(perfFix$cM, perfFix$totCost, col="red", type="b")
  plot(perfSeq$nItems, perfSeq$acc_mean, ylim=c(0, 1))
  abline(h=max(perfFix$acc_mean), col="red")
  cat("\n")
  cat("Prediction")
  
  predTab<- outPred$predAll
  predTab$cM<- as.character(predTab$cM)
  predSeq<- predTab[predTab$type=="dedaptive", ]
  print(table(predSeq$cM, predSeq$nItems))
  
  if(is.null(whichCost)==F){
    predSeqChosen<- predSeq[predSeq$cM==whichCost, ]
    return(list(perf=perfSeq, pred=predSeq, predChosen=predSeqChosen))
  }
  return(list(perf=perfSeq, pred=predSeq))
}


